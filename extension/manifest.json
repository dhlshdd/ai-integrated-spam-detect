{
  "manifest_version": 3,
  "name": "AI Sentinel: Scam & Phishing Detector",
  "version": "1.0",
  "description": "Real-time AI detection for social engineering, phishing, and scam sites.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Sentinel Dashboard"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
